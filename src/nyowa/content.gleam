// ---------------------------------------------------------------------------
// Dodge チェイスダイアログ（1-indexed、7以上は最後のセリフ）
// ---------------------------------------------------------------------------

pub fn dodge_dialogue(count: Int) -> String {
  case count {
    1 -> "えっ……にょわ……"
    2 -> "ちょっと待って……"
    3 -> "まだ仕事中なんで……"
    4 -> "もうちょっとだけ……"
    5 -> "にょわにょわ……！"
    6 -> "つかれてきた……にょわ……"
    _ -> "も、もう限界……にょわ……"
  }
}

